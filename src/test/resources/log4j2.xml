<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">
    <Appenders>

        <!-- Console output -->
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="%d{HH:mm:ss} %-5level [%c{1}] - %msg%n"/>
        </Console>

        <!-- File output — overwrites each run, lives in logs/app.log -->
        <File name="FileLogger" fileName="logs/app.log" append="false">
            <PatternLayout pattern="%d{dd-MM-yyyy HH:mm:ss} %-5level [%c{1}] - %msg%n"/>
        </File>

    </Appenders>

    <Loggers>
        <Root level="info">
<!--            <AppenderRef ref="Console"/>-->
            <AppenderRef ref="FileLogger"/>
        </Root>
    </Loggers>
</Configuration>
